  "work_item": {
    "schema_version": "work-item/v3",
    "work_statuses": [
      "active",
      "completed",
      "abandoned"
    ],
    "delivery_statuses": {
      "not_requested": {
        "allowed_work_statuses": [
          "active",
          "completed",
          "abandoned"
        ],
        "allowed_evidence": [],
        "required_evidence": []
      },
      "awaiting_approval": {
        "allowed_work_statuses": [
          "completed"
        ],
        "allowed_evidence": [],
        "required_evidence": []
      },
      "approved": {
        "allowed_work_statuses": [
          "completed"
        ],
        "allowed_evidence": [
          "approval_ref"
        ],
        "required_evidence": [
          "approval_ref"
        ]
      },
      "pr_created": {
        "allowed_work_statuses": [
          "completed"
        ],
        "allowed_evidence": [
          "approval_ref",
          "pr_url"
        ],
        "required_evidence": [
          "approval_ref",
          "pr_url"
        ]
      },
      "merged": {
        "allowed_work_statuses": [
          "completed"
        ],
        "allowed_evidence": [
          "approval_ref",
          "merge_sha"
        ],
        "required_evidence": [
          "approval_ref",
          "merge_sha"
        ]
      },
      "deployed": {
        "allowed_work_statuses": [
          "completed"
        ],
        "allowed_evidence": [
          "approval_ref",
          "merge_sha",
          "deployment_id"
        ],
        "required_evidence": [
          "approval_ref",
          "merge_sha",
          "deployment_id"
        ]
      }
    }
