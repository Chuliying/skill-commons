.DS_Store
.claude/settings.local.json

# Python bytecode from running bundle scripts
__pycache__/
*.pyc

# A maintainer's global excludes file may ignore .gitignore files; re-include
# them so repo and fixture ignore rules stay tracked in fresh checkouts.
!.gitignore

# Local environment files
.env
.env.*
!.env.example

# Optional private project markers consumed by the leakage guard. Never publish.
.local-leakage-patterns

# Generated agent-trigger dirs (source of truth = top-level skill folders, ADR-001)
# Regenerated by bootstrap/generate.sh from top-level skills.
.agents
.agents/
.claude/skills
.claude/skills/
.codex
.codex/
.cursor
.cursor/

# Real-agent eval workspaces and model logs
journey-evals/runs/

# Separately managed explainer-site repository; never stage it as a gitlink.
/website/
